AWS_ACCESS_KEY_ID=       # AWS access key ID for S3 authentication (Boto3 standard credential env var)
AWS_SECRET_ACCESS_KEY=   # AWS secret access key paired with AWS_ACCESS_KEY_ID
AWS_REGION=us-west-1     # Default AWS region for S3 operations (e.g. us-west-1); falls back to us-west-1 if unset
S3_BUCKET_NAME=          # Name of the S3 bucket used for RAG file storage (required for S3 source type)

# Vector Store Configuration
VECTOR_STORE_BACKEND=chroma  # Vector store backend: "chroma" (local, default) or "google" (Vertex AI Vector Search)

# Google Vertex AI Vector Search (required when VECTOR_STORE_BACKEND=google)
GCP_PROJECT_ID=              # Google Cloud project ID
GCP_REGION=us-central1       # GCP region for Vertex AI (e.g. us-central1)
GCP_GCS_BUCKET=              # GCS bucket name for staging vector data
GCP_VS_INDEX_ID=             # Vertex AI Vector Search index resource ID
GCP_VS_ENDPOINT_ID=          # Vertex AI Vector Search endpoint resource ID

GOOGLE_SA_CREDENTIALS_BASE64=            # your google api key json file contents encoded in base 64.
GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcp-sa-credentials.json  # Path where the decoded SA JSON will be written (used by GCP client libraries)